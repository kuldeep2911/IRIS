# I.R.I.S. v5 — environment template. Copy to `.env` and fill in.
# Secrets are read ONLY by iris/config/settings.py (GOLDEN RULE #8).

# ── Core / environment ───────────────────────────────────────────────────
ENV=local
LOG_LEVEL=INFO

# ── Multi-tenancy (single-user uses the default tenant) ──────────────────
DEFAULT_TENANT_ID=local

# ── Providers / secrets ──────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Data stores ──────────────────────────────────────────────────────────
# SQLite is fine for the first local run; Postgres via docker-compose.
DATABASE_URL=sqlite:///./iris.db
# REDIS_URL=redis://localhost:6379/0

# ── Model router thresholds (tunable knobs; no code change needed) ───────
ROUTER_SIMPLE_MAX_TOKENS=600
ROUTER_STANDARD_MAX_TOKENS=4000
ROUTER_LONG_CONTEXT_TOKENS=200000
ROUTER_DEFAULT_MAX_OUTPUT_TOKENS=2048
# ROUTER_FORCE_MODEL=

# ── Cost guards ──────────────────────────────────────────────────────────
DAILY_TOKEN_BUDGET=5000000

# ── Filesystem sandbox (filesystem/shell MCP may only touch this) ────────
WORKSPACE_DIR=./workspace

# ── Browser mesh (PHASE 2) ───────────────────────────────────────────────
# Real Chrome profile path so logged-in sessions (Gmail/WhatsApp/etc) are reused.
# Windows: C:\Users\<you>\AppData\Local\Google\Chrome\User Data
# BROWSER_USER_DATA_DIR=
# BROWSER_USE_SSE_URL=http://localhost:7801/sse
# BROWSER_MCP_SSE_URL=http://localhost:7802/sse
